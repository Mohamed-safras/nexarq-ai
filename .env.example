# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one provider is required. Ollama works offline (no key needed).
NEXARQ_ANTHROPIC_API_KEY=
NEXARQ_OPENAI_API_KEY=
NEXARQ_GOOGLE_API_KEY=
NEXARQ_OLLAMA_URL=http://localhost:11434
# MiniMax M1 — ultra-cheap coding model (~$0.10/1M tokens, 30x cheaper than GPT-4o)
# Get key: https://platform.minimaxi.com
NEXARQ_MINIMAX_API_KEY=
NEXARQ_MINIMAX_URL=https://api.minimax.io/v1

# Default provider: ollama | openai | anthropic | google | minimax
NEXARQ_DEFAULT_PROVIDER=ollama
NEXARQ_DEFAULT_MODEL=

# ── GitHub OAuth (CLI device flow) ────────────────────────────────────────────
NEXARQ_GITHUB_CLIENT_ID=

# ── Web App ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexarq:nexarq@localhost:5432/nexarq
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth app (web)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub token for posting PR review comments from the webhook handler
NEXARQ_GITHUB_TOKEN=
# GitHub webhook HMAC secret (set in repo/org settings)
NEXARQ_GITHUB_WEBHOOK_SECRET=

# ── Ads ───────────────────────────────────────────────────────────────────────
# Carbon Ads (web dashboard)
CARBON_ADS_CODE=
CARBON_ADS_PLACEMENT=

# EthicalAds (docs)
ETHICALADS_PUBLISHER_ID=

# ── Analytics ─────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# ── Stripe (enterprise self-host support — optional) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
