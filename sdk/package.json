{
  "name": "@nexarq/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Nexarq — programmatic multi-agent code review",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build":     "bun build src/index.ts --outdir dist --target node --format esm",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["code-review", "ai", "nexarq", "sdk"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexarq/nexarq"
  },
  "dependencies": {
    "@nexarq/common":        "workspace:*",
    "@nexarq/agent-runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript":  "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
