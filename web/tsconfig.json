{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@nexarq/common": [
        "../common/src/index.ts"
      ],
      "@nexarq/common/types": [
        "../common/src/types/index.ts"
      ],
      "@nexarq/common/interfaces": [
        "../common/src/interfaces/index.ts"
      ],
      "@nexarq/common/constants": [
        "../common/src/constants/index.ts"
      ],
      "@nexarq/common/utils": [
        "../common/src/utils/index.ts"
      ],
      "@nexarq/agent-runtime": [
        "../packages/agent-runtime/src/index.ts"
      ],
      "@nexarq/agent-runtime/*": [
        "../packages/agent-runtime/src/*.ts"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "src",
    "next.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
